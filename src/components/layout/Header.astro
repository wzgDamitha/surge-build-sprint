---
const navLinks = [
  { href: "/rules", label: "Rules" },
  { href: "/stack", label: "Stack" },
  { href: "/getting-started", label: "Get Started" },
  { href: "/leaderboard", label: "Leaderboard" },
  { href: "/faq", label: "FAQ" },
];

const currentPath = Astro.url.pathname;
---

<header
  class="sticky top-0 z-50 border-b"
  style="background: var(--nav-bg); border-color: var(--border); backdrop-filter: blur(16px); -webkit-backdrop-filter: blur(16px);"
>
  <div class="max-w-7xl mx-auto px-6 lg:px-10 flex items-center justify-between h-16">
    <a href="/" class="flex items-center gap-2 group">
      <svg width="16" height="22" viewBox="0 0 18 24" fill="none" class="transition-transform group-hover:rotate-12">
        <polygon points="10,0 0,14 8,14 7,24 18,10 10,10" fill="#ED1C24"/>
      </svg>
      <span class="font-heading font-bold text-base tracking-tight">
        surge <span class="text-surge">build sprint</span>
      </span>
    </a>

    <nav class="hidden md:flex items-center gap-1">
      {navLinks.map((link) => (
        <a
          href={link.href}
          class:list={[
            "px-4 py-2 text-sm font-medium rounded-full transition-colors",
            currentPath === link.href
              ? "text-white bg-surge"
              : "hover:bg-[var(--bg-surface)]",
          ]}
          style={currentPath !== link.href ? "color: var(--text-secondary);" : ""}
        >
          {link.label}
        </a>
      ))}
    </nav>

    <div class="flex items-center gap-3">
      <button
        id="theme-toggle"
        class="w-8 h-8 rounded-full border flex items-center justify-center text-xs cursor-pointer transition-colors hover:border-[var(--text-muted)]"
        style="border-color: var(--border); color: var(--text-muted);"
        aria-label="Toggle theme"
      >
        <span id="theme-icon-dark" class="hidden">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/></svg>
        </span>
        <span id="theme-icon-light" class="hidden">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
        </span>
      </button>

      <button
        id="mobile-menu-btn"
        class="md:hidden w-8 h-8 flex items-center justify-center"
        style="color: var(--text-secondary);"
        aria-label="Open menu"
      >
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <line x1="3" y1="6" x2="21" y2="6"/>
          <line x1="3" y1="12" x2="21" y2="12"/>
          <line x1="3" y1="18" x2="21" y2="18"/>
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile menu -->
  <div
    id="mobile-menu"
    class="hidden md:hidden border-t"
    style="border-color: var(--border); background: var(--bg-elevated);"
  >
    <nav class="flex flex-col p-4 gap-1">
      {navLinks.map((link) => (
        <a
          href={link.href}
          class:list={[
            "px-4 py-3 text-sm font-medium rounded-lg transition-colors",
            currentPath === link.href
              ? "text-white bg-surge"
              : "",
          ]}
          style={currentPath !== link.href ? "color: var(--text-secondary);" : ""}
        >
          {link.label}
        </a>
      ))}
    </nav>
  </div>
</header>

<script>
  function initHeader() {
    const toggle = document.getElementById("theme-toggle");
    const iconDark = document.getElementById("theme-icon-dark");
    const iconLight = document.getElementById("theme-icon-light");
    const mobileBtn = document.getElementById("mobile-menu-btn");
    const mobileMenu = document.getElementById("mobile-menu");

    function updateIcons() {
      const current = document.documentElement.getAttribute("data-theme");
      if (iconDark && iconLight) {
        iconDark.classList.toggle("hidden", current !== "dark");
        iconLight.classList.toggle("hidden", current !== "light");
      }
    }

    updateIcons();

    toggle?.addEventListener("click", () => {
      const current = document.documentElement.getAttribute("data-theme");
      const next = current === "dark" ? "light" : "dark";
      document.documentElement.setAttribute("data-theme", next);
      localStorage.setItem("theme", next);
      updateIcons();
    });

    mobileBtn?.addEventListener("click", () => {
      mobileMenu?.classList.toggle("hidden");
    });
  }

  initHeader();
  document.addEventListener("astro:after-swap", initHeader);
</script>

---
const navLinks = [
  { href: "/rules", label: "Rules" },
  { href: "/stack", label: "Stack" },
  { href: "/leaderboard", label: "Leaderboard" },
  { href: "/faq", label: "FAQ" },
];

const currentPath = Astro.url.pathname;
---

<header
  class="sticky top-0 z-50 border-b"
  style="background: var(--nav-bg); border-color: var(--border); backdrop-filter: blur(16px); -webkit-backdrop-filter: blur(16px);"
>
  <div class="max-w-7xl mx-auto px-6 lg:px-10 flex items-center justify-between h-16">
    <a href="/" class="flex items-center gap-2.5">
      <img src="/images/surge-bolt.png" alt="" width="20" height="32" />
      <div class="flex flex-col leading-none">
        <span class="font-heading font-extrabold text-lg tracking-tight">SURGE</span>
        <span class="font-heading font-medium text-[10px] tracking-wider text-surge">BUILD SPRINT</span>
      </div>
    </a>

    <nav class="hidden md:flex items-center gap-1">
      {navLinks.map((link) => (
        <a
          href={link.href}
          class:list={[
            "px-4 py-2 text-sm font-medium rounded-full transition-colors",
            currentPath === link.href
              ? "text-white bg-surge"
              : "hover:bg-[var(--bg-surface)]",
          ]}
          style={currentPath !== link.href ? "color: var(--text-secondary);" : ""}
        >
          {link.label}
        </a>
      ))}
    </nav>

    <div class="flex items-center gap-3">
      <a
        href="/getting-started"
        class="hidden md:inline-flex items-center px-5 py-2 bg-surge text-white font-heading font-bold text-[13px] rounded-full hover:-translate-y-0.5 transition-transform"
      >
        Get Started
      </a>
      <button
        id="theme-toggle"
        class="w-8 h-8 rounded-full border flex items-center justify-center text-xs cursor-pointer transition-colors hover:border-[var(--text-muted)]"
        style="border-color: var(--border); color: var(--text-muted);"
        aria-label="Toggle theme"
      >
        <span id="theme-icon-dark" class="hidden">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/></svg>
        </span>
        <span id="theme-icon-light" class="hidden">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
        </span>
      </button>

      <button
        id="mobile-menu-btn"
        class="md:hidden w-8 h-8 flex items-center justify-center relative"
        style="color: var(--text-secondary);"
        aria-label="Open menu"
      >
        <span id="icon-hamburger" class="transition-all duration-300">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <line x1="3" y1="6" x2="21" y2="6"/>
            <line x1="3" y1="12" x2="21" y2="12"/>
            <line x1="3" y1="18" x2="21" y2="18"/>
          </svg>
        </span>
        <span id="icon-close" class="absolute inset-0 flex items-center justify-center opacity-0 scale-75 transition-all duration-300">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <line x1="18" y1="6" x2="6" y2="18"/>
            <line x1="6" y1="6" x2="18" y2="18"/>
          </svg>
        </span>
      </button>
    </div>
  </div>
</header>

<!-- Mobile menu overlay -->
<div
  id="mobile-backdrop"
  class="fixed inset-0 z-40 bg-black/50 opacity-0 pointer-events-none transition-opacity duration-300 md:hidden"
></div>

<div
  id="mobile-menu"
  class="fixed top-0 right-0 z-50 h-full w-72 translate-x-full transition-transform duration-300 ease-out md:hidden flex flex-col"
  style="background: var(--bg-elevated);"
>
  <div class="flex items-center justify-between h-16 px-6 border-b" style="border-color: var(--border);">
    <span class="font-heading font-bold text-sm tracking-tight" style="color: var(--text-muted);">Menu</span>
    <button
      id="mobile-close-btn"
      class="w-8 h-8 flex items-center justify-center rounded-full"
      style="color: var(--text-secondary);"
      aria-label="Close menu"
    >
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <line x1="18" y1="6" x2="6" y2="18"/>
        <line x1="6" y1="6" x2="18" y2="18"/>
      </svg>
    </button>
  </div>

  <nav class="flex flex-col p-4 gap-1 flex-1">
    {navLinks.map((link, i) => (
      <a
        href={link.href}
        class:list={[
          "mobile-nav-link px-4 py-3.5 text-[15px] font-medium rounded-lg transition-all duration-300 opacity-0 translate-x-4",
          currentPath === link.href
            ? "text-white bg-surge"
            : "hover:bg-[var(--bg-surface)]",
        ]}
        style={`${currentPath !== link.href ? "color: var(--text-secondary);" : ""} transition-delay: ${(i + 1) * 50}ms;`}
      >
        {link.label}
      </a>
    ))}
  </nav>

  <div class="p-4 border-t" style="border-color: var(--border);">
    <a
      href="/getting-started"
      class="mobile-nav-link block py-3.5 text-center text-[15px] font-bold text-white bg-surge rounded-lg opacity-0 translate-x-4 transition-all duration-300"
      style={`transition-delay: ${(navLinks.length + 1) * 50}ms;`}
    >
      Get Started
    </a>
  </div>
</div>

<script>
  function initHeader() {
    const toggle = document.getElementById("theme-toggle");
    const iconDark = document.getElementById("theme-icon-dark");
    const iconLight = document.getElementById("theme-icon-light");
    const mobileBtn = document.getElementById("mobile-menu-btn");
    const mobileCloseBtn = document.getElementById("mobile-close-btn");
    const mobileMenu = document.getElementById("mobile-menu");
    const backdrop = document.getElementById("mobile-backdrop");
    const iconHamburger = document.getElementById("icon-hamburger");
    const iconClose = document.getElementById("icon-close");

    function updateIcons() {
      const current = document.documentElement.getAttribute("data-theme");
      if (iconDark && iconLight) {
        iconDark.classList.toggle("hidden", current !== "dark");
        iconLight.classList.toggle("hidden", current !== "light");
      }
    }

    updateIcons();

    toggle?.addEventListener("click", () => {
      const current = document.documentElement.getAttribute("data-theme");
      const next = current === "dark" ? "light" : "dark";
      document.documentElement.setAttribute("data-theme", next);
      localStorage.setItem("theme", next);
      updateIcons();
    });

    function openMenu() {
      mobileMenu?.classList.remove("translate-x-full");
      backdrop?.classList.remove("opacity-0", "pointer-events-none");
      document.body.style.overflow = "hidden";

      if (iconHamburger && iconClose) {
        iconHamburger.style.opacity = "0";
        iconHamburger.style.transform = "scale(0.75) rotate(90deg)";
        iconClose.style.opacity = "1";
        iconClose.style.transform = "scale(1) rotate(0deg)";
      }

      mobileMenu?.querySelectorAll(".mobile-nav-link").forEach((link) => {
        (link as HTMLElement).style.opacity = "1";
        (link as HTMLElement).style.transform = "translateX(0)";
      });
    }

    function closeMenu() {
      mobileMenu?.classList.add("translate-x-full");
      backdrop?.classList.add("opacity-0", "pointer-events-none");
      document.body.style.overflow = "";

      if (iconHamburger && iconClose) {
        iconHamburger.style.opacity = "1";
        iconHamburger.style.transform = "scale(1) rotate(0deg)";
        iconClose.style.opacity = "0";
        iconClose.style.transform = "scale(0.75) rotate(-90deg)";
      }

      mobileMenu?.querySelectorAll(".mobile-nav-link").forEach((link) => {
        (link as HTMLElement).style.opacity = "0";
        (link as HTMLElement).style.transform = "translateX(1rem)";
      });
    }

    mobileBtn?.addEventListener("click", openMenu);
    mobileCloseBtn?.addEventListener("click", closeMenu);
    backdrop?.addEventListener("click", closeMenu);

    mobileMenu?.querySelectorAll("a").forEach((link) => {
      link.addEventListener("click", closeMenu);
    });
  }

  initHeader();
  document.addEventListener("astro:after-swap", initHeader);
</script>

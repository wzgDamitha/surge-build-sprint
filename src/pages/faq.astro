---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/layout/Header.astro";
import Footer from "../components/layout/Footer.astro";

const faqs = [
  {
    category: "General",
    items: [
      {
        q: "What is Surge Build Sprint?",
        a: "A 4-day hackathon by Surge where developers build brochure websites for Colombo Stock Exchange brokers using AI tools. The twist: the result cannot look AI-generated.",
      },
      {
        q: "Is this a team event?",
        a: "No. Participation is solo. You may ask AI anything. You may not ask another human for help on the build itself. Discussing approach with peers is fine.",
      },
      {
        q: "What do I receive on Day 0?",
        a: "One showcase website to revamp (a CSE broker or listed company), the fully scraped content (text, structure, image references), and the original site URL for reference.",
      },
      {
        q: "Do I get brand guidelines or design files?",
        a: "No. No brand guidelines, no visual direction, no color palettes, no logo files. These are your design decisions. They are part of what we're scoring.",
      },
    ],
  },
  {
    category: "Rules",
    items: [
      {
        q: "Can I use a design system from Figma?",
        a: "You can use it for inspiration, not as a starting kit. Build your components from scratch.",
      },
      {
        q: "Can I add features beyond the original scope?",
        a: "Yes, as long as the core brochure pages exist and everything stays editable in Strapi.",
      },
      {
        q: "What counts as a pre-built component library?",
        a: "Anything that ships ready-made styled components: shadcn/ui, DaisyUI, Material UI, Mantine, Chakra, Radix Themes, Park UI. Tailwind is fine. Headless primitives for accessibility (Radix UI primitives, Headless UI) are fine if you actually need them.",
      },
      {
        q: "Can I use starter templates?",
        a: "No. Beyond create astro defaults, your first commit gets checked. Build from scratch.",
      },
    ],
  },
  {
    category: "Technical",
    items: [
      {
        q: "Can I generate images with AI?",
        a: "Yes. Document which tool you used. Be tasteful — bad AI imagery is an AI tell and will cost you points.",
      },
      {
        q: "Can I use Claude Code for everything including content writing?",
        a: "You can. But generic AI copy will cost you points under the Content & Copy category. Your job is to direct it well and edit ruthlessly.",
      },
      {
        q: "What if my assigned site is really boring?",
        a: "That's the point. Brokerage sites are conservative by genre. Escaping the template within tight constraints is the actual test.",
      },
      {
        q: "Do I need to use Railway specifically?",
        a: "Yes. Both the Astro frontend and Strapi backend must be deployed on Railway. This is a hard requirement.",
      },
    ],
  },
  {
    category: "Judging",
    items: [
      {
        q: "What happens if Lighthouse scores miss 95?",
        a: "You can still submit and be scored, but you're out of contention for top 3 placement.",
      },
      {
        q: "What is the live code review?",
        a: "A judge picks a random file from your repo and asks you to explain it. If you cannot explain your own code, that's a signal. This is a 5-minute segment during your 15-minute judging slot.",
      },
      {
        q: "What is the custom-craft element?",
        a: "Something where AI gets you 70% there and the last 30% is you. A custom hero treatment, a non-template team grid, an interactive map, hand-tuned scroll behavior, a custom SVG illustration. Document which element this is in your SUBMISSION.md.",
      },
      {
        q: "How does the AI smell deduction work?",
        a: "Judges independently flag visible AI tells: generic components, default spacing, slate/zinc palettes, icon decoration, LLM-flavored copy, purposeless gradients, stock imagery. Each tell costs 1-3 points depending on severity.",
      },
    ],
  },
];
---

<BaseLayout title="FAQ" description="Frequently asked questions about Surge Build Sprint.">
  <Header slot="header" />

  <!-- PAGE HEADER -->
  <section class="max-w-7xl mx-auto px-6 lg:px-10 pt-20 pb-12 lg:pt-28 lg:pb-16">
    <p class="text-xs font-semibold uppercase tracking-[0.15em] mb-4" style="color: var(--text-muted);">
      Questions
    </p>
    <h1 class="font-heading font-extrabold text-4xl sm:text-5xl lg:text-[3.5rem] tracking-tighter leading-none mb-5">
      FAQ
    </h1>
    <p class="text-sm leading-relaxed max-w-xl" style="color: var(--text-secondary);">
      Everything you need to know before Day 1.
    </p>
  </section>

  <!-- FAQ SECTIONS -->
  <section class="max-w-7xl mx-auto px-6 lg:px-10 pb-20 lg:pb-28">
    <div class="space-y-12 lg:space-y-16">
      {faqs.map((section) => (
        <div class="grid lg:grid-cols-[200px_1fr] gap-6 lg:gap-12">
          <div class="lg:sticky lg:top-24 lg:self-start">
            <h2 class="font-heading font-bold text-xl tracking-tight">{section.category}</h2>
            <p class="text-xs mt-1" style="color: var(--text-muted);">
              {section.items.length} questions
            </p>
          </div>

          <div
            class="border rounded-xl overflow-hidden"
            style="border-color: var(--border);"
          >
            {section.items.map((faq, i) => (
              <details
                class:list={[
                  "group",
                  i > 0 && "border-t",
                ]}
                style={i > 0 ? "border-color: var(--border);" : ""}
              >
                <summary class="flex items-start justify-between gap-4 p-5 cursor-pointer select-none transition-colors hover:bg-[var(--card-hover)] list-none [&::-webkit-details-marker]:hidden">
                  <span class="font-heading font-semibold text-[15px] leading-snug">{faq.q}</span>
                  <span
                    class="shrink-0 w-6 h-6 rounded-full border flex items-center justify-center text-xs transition-transform group-open:rotate-45"
                    style="border-color: var(--border); color: var(--text-muted);"
                  >
                    +
                  </span>
                </summary>
                <div class="px-5 pb-6 pt-1">
                  <p class="text-[13px] leading-[1.8]" style="color: var(--text-secondary);">
                    {faq.a}
                  </p>
                </div>
              </details>
            ))}
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- STILL HAVE QUESTIONS -->
  <section class="max-w-7xl mx-auto px-6 lg:px-10 pb-20 lg:pb-28">
    <div
      class="rounded-xl border p-10 lg:p-12 text-center"
      style="background: var(--bg-elevated); border-color: var(--border);"
    >
      <h3 class="font-heading font-bold text-xl tracking-tight mb-2">Still have questions?</h3>
      <p class="text-xs mb-6" style="color: var(--text-secondary);">
        Reach out to the Surge team directly.
      </p>
      <a
        href="https://surge.global"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center px-7 py-3 bg-surge text-white font-heading font-bold text-sm rounded-full hover:-translate-y-0.5 hover:shadow-lg transition-all"
      >
        Contact Surge
      </a>
    </div>
  </section>

  <Footer slot="footer" />
</BaseLayout>

---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/layout/Header.astro";
import Footer from "../components/layout/Footer.astro";
import Countdown from "../components/marketing/Countdown.astro";

const targetDate = "2026-05-11T12:00:00+05:30";
---

<BaseLayout title="Home">
  <Header slot="header" />

  <!-- HERO -->
  <section class="relative overflow-hidden" style="min-height: 520px;">
    <div class="absolute inset-0 bg-gradient-to-br from-[#8B0000] via-[#ED1C24] via-40% to-[#8B0000]"></div>

    <div
      class="absolute inset-0"
      style="background-image: radial-gradient(ellipse at 70% 30%, rgba(255,255,255,0.08) 0%, transparent 60%), radial-gradient(ellipse at 30% 70%, rgba(0,0,0,0.2) 0%, transparent 50%);"
    ></div>

    <div
      class="absolute inset-0 opacity-40"
      style="background-image: radial-gradient(circle, rgba(255,255,255,0.06) 1px, transparent 1px); background-size: 32px 32px;"
    ></div>

    <div class="relative z-10 max-w-7xl mx-auto px-6 lg:px-10 flex items-end" style="min-height: 520px;">
      <div class="absolute right-6 lg:right-10 top-12 w-56 h-80 opacity-10 hidden lg:block">
        <img src="/images/surge-bolt-white.png" alt="" class="w-full h-full object-contain" />
      </div>
      <div class="pb-16 pt-24 lg:pt-32 max-w-2xl">
        <p class="text-xs font-semibold uppercase tracking-[0.15em] text-white/70 mb-5">
          Surge Build Sprint // 2026
        </p>
        <h1 class="font-heading font-extrabold text-5xl sm:text-6xl lg:text-7xl tracking-tighter leading-none text-white mb-5">
          Build with AI.<br/>
          Don't ship slop.
        </h1>
        <p class="text-base text-white/70 max-w-lg leading-relaxed mb-8">
          4 days. One website. Astro, Strapi, Railway, Claude Code. If it looks like a default template, you've already lost.
        </p>
        <div class="flex flex-wrap gap-3">
          <a
            href="/rules"
            class="inline-flex items-center px-8 py-3.5 bg-white text-[#ED1C24] font-heading font-bold text-sm rounded-full hover:-translate-y-0.5 hover:shadow-xl transition-all"
          >
            Read the Rules
          </a>
          <a
            href="/getting-started"
            class="inline-flex items-center px-7 py-3 text-white font-heading font-semibold text-sm rounded-full border-[1.5px] border-white/40 hover:border-white transition-colors"
          >
            Get Started
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- COUNTDOWN -->
  <section class="max-w-7xl mx-auto px-6 lg:px-10 -mt-8 relative z-20">
    <Countdown targetDate={targetDate} />
  </section>

  <!-- PREMISE -->
  <section class="max-w-7xl mx-auto px-6 lg:px-10 py-20 lg:py-28">
    <div class="grid lg:grid-cols-[1.8fr_1fr] gap-10 lg:gap-16 items-start">
      <div>
        <h2 class="font-heading font-bold text-2xl sm:text-3xl lg:text-[2.2rem] tracking-tight leading-snug mb-4">
          Can you direct AI well enough that the result doesn't look AI-generated?
        </h2>
        <p class="text-sm leading-relaxed max-w-lg" style="color: var(--text-secondary);">
          Speed pushes you toward accepting whatever AI generates. Taste pushes you toward slowing down and refining. The whole point is to see who resolves that tension — who develops a workflow where AI handles the boring 80% at full speed, freeing you to spend real time on the parts that need taste.
        </p>
      </div>
      <div
        class="rounded-xl border p-8"
        style="background: var(--bg-elevated); border-color: var(--border);"
      >
        <div class="text-[13px] leading-[2.2] font-mono" style="color: var(--text-secondary);">
          <span class="text-surge">$</span> Build a website.<br/>
          <span class="text-surge">$</span> Use AI for everything.<br/>
          <span class="text-surge">$</span> Make it not look like AI.<br/>
          <span class="text-surge">$</span> You have 4 days.<br/>
          <span class="text-surge opacity-60">_</span>
        </div>
      </div>
    </div>
  </section>

  <!-- WHAT WE MEASURE -->
  <section class="max-w-7xl mx-auto px-6 lg:px-10 pb-20 lg:pb-28">
    <div
      class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 border rounded-xl overflow-hidden"
      style="border-color: var(--border);"
    >
      <div class="p-8 border-b sm:border-r lg:border-b-0 lg:border-r" style="border-color: var(--border);">
        <h3 class="font-heading font-bold text-lg mb-1">We measure three things</h3>
        <p class="text-[11px]" style="color: var(--text-muted);">Not speed. Not quantity.</p>
      </div>
      <div
        class="p-8 border-b lg:border-b-0 lg:border-r transition-colors hover:bg-[var(--card-hover)]"
        style="border-color: var(--border);"
      >
        <div class="font-heading font-bold text-5xl tracking-tight leading-none mb-2">01</div>
        <p class="text-xs" style="color: var(--text-secondary);">AI Direction</p>
      </div>
      <div
        class="p-8 border-b sm:border-r lg:border-b-0 lg:border-r transition-colors hover:bg-[var(--card-hover)]"
        style="border-color: var(--border);"
      >
        <div class="font-heading font-bold text-5xl tracking-tight leading-none mb-2">02</div>
        <p class="text-xs" style="color: var(--text-secondary);">Taste</p>
      </div>
      <div class="p-8 transition-colors hover:bg-[var(--card-hover)]">
        <div class="font-heading font-bold text-5xl tracking-tight leading-none mb-2">03</div>
        <p class="text-xs" style="color: var(--text-secondary);">Full-Stack Orchestration</p>
      </div>
    </div>
  </section>

  <!-- CTA DUO -->
  <section class="max-w-7xl mx-auto px-6 lg:px-10 pb-20 lg:pb-28">
    <div class="grid md:grid-cols-2 gap-1 rounded-xl overflow-hidden">
      <div class="bg-[#111] text-white p-10 lg:p-12 flex flex-col justify-end min-h-[260px]">
        <span class="text-[11px] px-3.5 py-1 border border-white/30 rounded-full inline-block w-fit mb-4 text-white/80">
          Stakes
        </span>
        <h3 class="font-heading font-bold text-2xl tracking-tight leading-tight mb-3">
          Your reputation.<br/>And bragging rights.
        </h3>
        <p class="text-xs text-white/50 leading-relaxed mb-4">
          Top 3 featured on Surge portfolio. Winner gets client project priority.
        </p>
        <a href="/rules" class="text-xs text-white/60 hover:text-white transition-colors">
          Read Full Brief
        </a>
      </div>

      <div
        class="text-white p-10 lg:p-12 flex flex-col justify-end min-h-[260px] relative overflow-hidden"
        style="background: linear-gradient(135deg, #8B0000, #ED1C24 50%, #CC1018);"
      >
        <span class="text-[11px] px-3.5 py-1 border border-white/30 rounded-full inline-block w-fit mb-4 text-white/80">
          Get Ready
        </span>
        <h3 class="font-heading font-bold text-2xl tracking-tight leading-tight mb-5">
          Check the stack.<br/>Read the rules.
        </h3>
        <div class="flex gap-3">
          <a
            href="/stack"
            class="inline-flex items-center px-6 py-2.5 bg-white text-[#ED1C24] font-heading font-bold text-[13px] rounded-full hover:-translate-y-0.5 transition-transform"
          >
            View Stack
          </a>
          <a
            href="/faq"
            class="inline-flex items-center px-5 py-2 text-white font-heading font-semibold text-[13px] rounded-full border-[1.5px] border-white/40 hover:border-white transition-colors"
          >
            FAQ
          </a>
        </div>
      </div>
    </div>
  </section>

  <Footer slot="footer" />
</BaseLayout>
